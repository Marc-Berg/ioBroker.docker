name: Build and Push Docker Image
on:
 push:
   branches:
     - main
jobs:
 build_arm_v7:
   runs-on: ubuntu-latest
   steps:
     - name: Checkout code
       uses: actions/checkout@v4
     
     - name: Set up QEMU
       uses: docker/setup-qemu-action@v3.2.0
     
     - name: Set up Docker Buildx
       uses: docker/setup-buildx-action@v3.7.1
     
     - name: Log in to Docker Hub
       uses: docker/login-action@v3.3.0
       with:
         username: ${{ secrets.DOCKERHUB_USERNAME }}
         password: ${{ secrets.DOCKERHUB_PASSWORD }}
     
     - name: Build and push Docker image for arm/v7
       uses: docker/build-push-action@v5
       with:
         context: ./debian12
         platforms: linux/arm/v7
         push: false
         load: true
         tags: arm_v7_image
 
 build_amd64:
   runs-on: ubuntu-latest
   steps:
     - name: Checkout code
       uses: actions/checkout@v4
     
     - name: Set up Docker Buildx
       uses: docker/setup-buildx-action@v3.7.1
     
     - name: Log in to Docker Hub
       uses: docker/login-action@v3.3.0
       with:
         username: ${{ secrets.DOCKERHUB_USERNAME }}
         password: ${{ secrets.DOCKERHUB_PASSWORD }}
     
     - name: Build and push Docker image for amd64
       uses: docker/build-push-action@v5
       with:
         context: ./debian12
         platforms: linux/amd64
         push: false
         load: true
         tags: amd64_image
 
 build_arm64_v8:
   runs-on: ubuntu-latest
   steps:
     - name: Checkout code
       uses: actions/checkout@v4
     
     - name: Set up QEMU
       uses: docker/setup-qemu-action@v3.2.0
     
     - name: Set up Docker Buildx
       uses: docker/setup-buildx-action@v3.7.1
     
     - name: Log in to Docker Hub
       uses: docker/login-action@v3.3.0
       with:
         username: ${{ secrets.DOCKERHUB_USERNAME }}
         password: ${{ secrets.DOCKERHUB_PASSWORD }}
     
     - name: Build and push Docker image for arm64/v8
       uses: docker/build-push-action@v5
       with:
         context: ./debian12
         platforms: linux/arm64/v8
         push: false
         load: true
         tags: arm64_v8_image
 
 create_and_push_multiarch_image:
   runs-on: ubuntu-latest
   needs: [build_arm_v7, build_amd64, build_arm64_v8]
   steps:
     - name: Log in to Docker Hub
       uses: docker/login-action@v3.3.0
       with:
         username: ${{ secrets.DOCKERHUB_USERNAME }}
         password: ${{ secrets.DOCKERHUB_PASSWORD }}
     
     - name: Create and push multi-platform image
       run: |
         docker buildx imagetools create -t marcberg/iobroker2:latest \
           $(docker images -q arm_v7_image) \
           $(docker images -q amd64_image) \
           $(docker images -q arm64_v8_image)
         docker buildx imagetools create -t marcberg/iobroker2:v10.0.0 \
           $(docker images -q arm_v7_image) \
           $(docker images -q amd64_image) \
           $(docker images -q arm64_v8_image)
